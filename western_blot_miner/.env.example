# Copy to .env (or just export these) before running.

# Required: your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: NCBI E-utilities API key — raises rate limit 3->10 req/sec
NCBI_API_KEY=
NCBI_EMAIL=you@example.com

# Optional: override the model (default claude-opus-4-8).
# claude-sonnet-4-6 is cheaper for large bulk runs; claude-haiku-4-5 cheapest.
WBM_MODEL=claude-opus-4-8

# Optional: OpenAI-compatible VLM endpoint for local PDF crops.
WBM_VLM_BASE_URL=https://your-runpod-host/v1
WBM_VLM_API_KEY=
WBM_VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# Optional: Supabase upload target for flattened VLM band records.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=
SUPABASE_TABLE=western_blot_records
SUPABASE_IDEMPOTENT=true
