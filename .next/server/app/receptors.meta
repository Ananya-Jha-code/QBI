{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/receptors/layout,_N_T_/receptors/page,_N_T_/receptors"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/receptors/__PAGE__",
    "/receptors",
    "/_index",
    "/_head"
  ]
}